# Supabase — public client credentials (safe to expose to the browser).
# Real values live in the Render dashboard; this file only documents the names.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# OpenAI — server-side only, NEVER exposed to the browser. Set in Render.
# OPENAI_MODEL is optional (defaults to gpt-4o-mini).
OPENAI_API_KEY=
OPENAI_MODEL=

# Supabase service-role key — server-side ONLY, bypasses RLS. Used by the
# widget to read jobs/profiles (public widget has no user session). Never
# expose to the browser. From Supabase → Project settings → API → service_role.
SUPABASE_SERVICE_ROLE_KEY=
